{
  "name": "rzem-ai-skillful-claude",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "out/main/index.js",
  "author": {
    "email": "alex@rzem.com",
    "name": "rzem.ai",
    "url": "http://rzem.guru"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:icons": "node scripts/gen-icons-page.mjs",
    "package": "npm run build && electron-builder --publish=never",
    "package:linux": "npm run build && electron-builder --linux --publish=never",
    "package:mac": "npm run build && electron-builder --mac --publish=never",
    "package:win": "npm run build && electron-builder --win --publish=never",
    "release": "npm run build && electron-builder --publish=always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-light-svg-icons": "^7.2.0",
    "@fortawesome/pro-regular-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "electron-log": "^5.2.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "description": "What Claude Code configuration is actually in effect, and why — a desktop diagnostic for the five config scopes."
}
