{
  "name": "rzem-ai-skillful-claude",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "package": "npm run build && electron-builder --publish=never",
    "package:linux": "npm run build && electron-builder --linux --publish=never",
    "package:mac": "npm run build && electron-builder --mac --publish=never",
    "package:win": "npm run build && electron-builder --win --publish=never",
    "release": "npm run build && electron-builder --publish=always",
    "icons": "node scripts/build-icons.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@milkdown/core": "^7.20.0",
    "@milkdown/ctx": "^7.20.0",
    "@milkdown/plugin-listener": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@milkdown/transformer": "^7.20.0",
    "@milkdown/vue": "^7.20.0",
    "@primeuix/themes": "^2.0.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vue-flow/node-resizer": "^1.5.1",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "gray-matter": "^4.0.3",
    "pinia": "^3.0.4",
    "primevue": "^4.5.4",
    "skills": "^1.4.9",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.27",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^5.0.0",
    "sharp": "^0.33.5",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
