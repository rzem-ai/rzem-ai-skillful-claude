{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skillful Claude",
  "version": "0.1.0",
  "identifier": "ai.rzem.skillful-claude",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skillful Claude",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.example.com/skillful-claude/{{target}}/{{current_version}}/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBKEY"
    }
  }
}
