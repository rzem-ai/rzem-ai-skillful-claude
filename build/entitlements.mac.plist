<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime entitlements for the Electron app.
    `mac.hardenedRuntime: true` in electron-builder.yml locks the runtime
    down; without these exceptions Chromium's V8 engine cannot allocate
    JIT memory and the app crashes immediately on launch.
  -->

  <!-- V8 compiles JS to native code at runtime — needs a writable+executable
       code cache. Required for any Electron app under hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Chromium maps executable pages that aren't signed by us. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Some Electron/Chromium paths disable library validation so the app
       can load frameworks/helpers not signed with the same Team ID. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
